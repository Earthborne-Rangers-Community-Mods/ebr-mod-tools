{
  "name": "ebr-mod-tools-gui",
  "version": "0.1.0",
  "description": "Electron desktop app for Earthborne Rangers mod creators. A GUI front end over the workspace core package.",
  "private": true,
  "main": "./out/main/index.js",
  "author": "Sunberry Keeper",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "core": "*"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.21.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "electron": "43.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "emoji-picker-element": "^1.29.1",
    "emoji-picker-element-data": "^1.8.0",
    "iso-639-1": "^3.1.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "vite": "^7.0.0",
    "vite-plugin-electron-renderer": "^0.14.7"
  }
}
